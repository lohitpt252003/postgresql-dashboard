# Frontend Development Dockerfile - React with npm start
FROM node:18-alpine

WORKDIR /app

# Copy package file
COPY package.json ./

# Install dependencies
RUN npm install

# Expose port
EXPOSE 3000

# Set environment variables
ENV REACT_APP_API_URL=http://localhost:8001
ENV CHOKIDAR_USEPOLLING=true

# Start development server with hot reload
CMD ["npm", "start"]
